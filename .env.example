# =============================================================================
# ZC Prontuário — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# Server
PORT=3001
NODE_ENV=development

# Banco de dados (PostgreSQL via docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=admin_password
DB_NAME=zc_prontuario

# Porta exposta pelo Docker host (apenas dev local)
DB_PORT_HOST=5433

# JWT (access token — curta duração)
JWT_SECRET=troque_por_um_segredo_forte_de_pelo_menos_32_chars
JWT_EXPIRES_IN=15m

# JWT (refresh token — longa duração)
JWT_REFRESH_SECRET=refresh-segredo-diferente-e-forte
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origem do frontend
CORS_ORIGIN=http://localhost:3000

